# 本地开发环境变量
# 注意: 此文件包含开发环境密钥，不要提交到 Git
# 生产环境使用 wrangler secret put 命令设置

# JWT 密钥 (用于签发 token)
JWT_SECRET=local-dev-jwt-secret-change-this-in-production-min-32-chars

# Gemini API 主密钥 (用于加密用户的 API keys)
GEMINI_MASTER_KEY=local-dev-gemini-master-key-change-this-32-chars

# Azure API 主密钥 (用于加密 Azure Speech Service keys)
AZURE_MASTER_KEY=local-dev-azure-master-key-change-this-now-32

# 环境标识
ENVIRONMENT=development
